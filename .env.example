# ──────────────────────────────────────────────
# NutricIA — Root Environment Variables
# Used by docker-compose.yml and shared across services
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=nutricia
POSTGRES_PORT=5432

# ── pgAdmin ──────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@nutricia.local
PGADMIN_DEFAULT_PASSWORD=admin

# ── Backend ──────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/nutricia
JWT_SECRET=change-me-in-production
DEBUG=true

# ── AI Provider: "gemini" | "openai" ─────────
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# ── Frontend ─────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
