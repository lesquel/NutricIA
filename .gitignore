# ──────────────────────────────────────────────
# NutricIA — Root .gitignore
# ──────────────────────────────────────────────

# Environment variables
.env
.env.local
.env.*.local
!.env.example

# OS
.DS_Store
Thumbs.db
*.swp
*~

# IDEs
.idea/
.vscode/
*.code-workspace

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Expo / React Native
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
ios/
android/

# Docker
docker-compose.override.yml

# Misc
*.log
tmp/
temp/
